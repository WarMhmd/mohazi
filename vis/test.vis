birth:
    childName:
        type: string
        defaultError: "Child name is invalid"
        required: true
        rules:
            minLength: 
                value: 3
                error: "Child name cannot be shorter than 3 characters."
            maxLength:
                value: 20
                error: "Child name cannot be longer than 20 characters."
    dateOfBirth:
        type: date
        required: true
        defaultError: "Invalid date of birth"
        transform:
            format: "YYYY-mm-dd"
    id:
        type: uuid 
        required: true 
        defaultError: "Invalid UUID"
        rules:
            version: "v4"
