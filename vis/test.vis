login: 
	username: 
        type: string
        required: true
        rules:
            maxLength: 4,
            error: "This is maxLength error"
        defaultError: "Invalid username."
        transform:
            trim: true
            uppercase: true
        rules:
            minLength: 3
            error: "Username must be at least 3 characters." # This is a comment
            pattern:
                value: "^[a-zA-Z0-9_]+$"
                error: "Username can only contain letters, numbers, and underscores."
        transform:
            split: ","
            cast: number
        
